# Horizon Security Config
HORIZON_DB_PATH=data/horizon.sqlite
HORIZON_BACKUP_DIR=backups
HORIZON_SESSION_TTL_MINUTES=480
HORIZON_IDLE_TIMEOUT_MINUTES=60
HORIZON_REAUTH_TTL_MINUTES=5
HORIZON_MAX_LOGIN_FAILURES=5
HORIZON_LOCKOUT_MINUTES=15
HORIZON_BACKUP_RETENTION_DAYS=30
HORIZON_ENABLE_DEVTOOLS_BARRIER=1
HORIZON_INTEGRITY_TABLES=security_users,security_permissions,registros,apontamentos,oee_registros

# Futuro Supabase:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# NUNCA colocar SUPABASE_SERVICE_ROLE_KEY no frontend.
